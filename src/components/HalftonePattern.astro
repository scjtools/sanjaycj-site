---
// Full-bleed interactive pixel field: a sparse star scatter, a low-rise
// "background city" filling the canvas width, and a KL skyline of named
// landmarks rising above it. Mouse repels nearby pixels and leaves spark
// trails; physics runs client-side (see script). Landmarks sit at fixed
// offsets from centre and drop out whole when they don't fit; the filler
// city regenerates to the canvas width every resize.
interface Props {
  class?: string;
  showSkyline?: boolean;
  showFiller?: boolean;
  showAmbient?: boolean;
  /** Custom building set drawn instead of the default skyline (e.g. the
   * About page's country silhouettes). */
  buildings?: { x0: number; grid: string[] }[];
  /** Scale the skyline to fit the width instead of dropping overflow. */
  fit?: boolean;
  /** Fraction of cells that become ambient particles (default 0.02). */
  density?: number;
}

const {
  class: className = "",
  showSkyline = true,
  showFiller = showSkyline,
  showAmbient = true,
  buildings,
  fit = false,
  density,
} = Astro.props;
---

<canvas
  class={`absolute inset-0 h-full w-full pixelated ${className}`}
  data-halftone
  data-skyline={showSkyline ? "true" : "false"}
  data-filler={showFiller ? "true" : "false"}
  data-ambient={showAmbient ? "true" : "false"}
  data-fit={fit ? "true" : "false"}
  data-density={density !== undefined ? String(density) : undefined}
  data-buildings={buildings ? JSON.stringify(buildings) : undefined}
  aria-hidden="true"
></canvas>

<script>
  interface Particle {
    ox: number;
    oy: number;
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    color: string;
  }

  interface Spark {
    x: number;
    y: number;
    vx: number;
    vy: number;
    age: number;
    life: number;
    size: number;
    color: string;
  }

  interface Rig {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    w: number;
    h: number;
    particles: Particle[];
    sparks: Spark[];
    lastSparkX: number;
    lastSparkY: number;
    visible: boolean;
  }

  function hash(x: number, y: number) {
    const n = Math.sin(x * 127.1 + y * 311.7) * 43758.5453123;
    return n - Math.floor(n);
  }

  // Randomly scattered stars; count scales with area × threshold (density).
  function buildAmbient(w: number, h: number, colors: string[], threshold = 0.02): Particle[] {
    const cell = 12;
    const count = Math.round((w / cell) * (h / cell) * threshold);

    const particles: Particle[] = [];
    for (let i = 0; i < count; i++) {
      const cx = Math.random() * w;
      const cy = Math.random() * h;
      const roll = Math.random();
      const color = roll < 0.08 ? colors[1] : roll < 0.16 ? colors[2] : roll < 0.24 ? colors[3] : colors[0];
      const size = 2 + Math.round(Math.random() * 3);
      particles.push({ ox: cx, oy: cy, x: cx, y: cy, vx: 0, vy: 0, size, color });
    }
    return particles;
  }

  // Pixel-art grid ('#' filled, '.' empty), bottom row on the ground line.
  // `x0` is the grid's left-edge offset from canvas-centre (in px).
  interface Building {
    x0: number;
    grid: string[];
