---
import "../styles/global.css";
import { site } from "../data/site";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ContactModal from "../components/ContactModal.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Home", description = "An engineer with expertise in audit and finance, building digital tools that solve everyday problems." } = Astro.props;
const pageTitle = `${title} | Sanjay Joshi`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL("/og-image.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/sprites/favicon-pal-01.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0b0e14" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sanjay Joshi" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content="Sanjay Joshi - Auditor, Engineer, Builder" />
    <meta property="og:description" content="An engineer with expertise in audit and finance, building digital tools that solve everyday problems." />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Sanjay Joshi - Auditor, Engineer, Builder" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content="Sanjay Joshi - Auditor, Engineer, Builder" />
    <meta name="twitter:description" content="An engineer with expertise in audit and finance, building digital tools that solve everyday problems." />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Sanjay Joshi - Auditor, Engineer, Builder" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Sanjay Joshi",
        "url": "https://sanjaycj.com",
        "jobTitle": "Auditor, Engineer, Builder",
        "description": "An engineer with expertise in audit and finance, building digital tools that solve everyday problems.",
        "sameAs": ["https://github.com/scjtools", "https://www.linkedin.com/in/sanjay-joshi/"],
        "image": "https://sanjaycj.com/og-image.png"
      }
    </script>

    <ClientRouter />
  </head>
  <body class="bg-bg text-ink">
    <ContactModal />
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
